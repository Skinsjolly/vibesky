# VibeSky Environment Variables
# Copy this file to .env.local and fill in your values

# Database (PostgreSQL connection string)
# For local dev: postgresql://postgres:password@localhost:5432/vibesky
# For Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/vibesky?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/vibesky"

# JWT Secret — generate with: openssl rand -base64 32
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# App URL (for OAuth callbacks, emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Cloudflare R2 for image uploads (not required for demo)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""
